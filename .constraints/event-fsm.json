{
  "id": "event-fsm",
  "version": 1,
  "description": "8-state event lifecycle with strict transition rules. Source of truth: lib/events/transitions.ts",
  "states": [
    "draft",
    "proposed",
    "accepted",
    "paid",
    "confirmed",
    "in_progress",
    "completed",
    "cancelled"
  ],
  "transitions": {
    "draft": ["proposed", "paid", "cancelled"],
    "proposed": ["accepted", "cancelled"],
    "accepted": ["paid", "cancelled"],
    "paid": ["confirmed", "cancelled"],
    "confirmed": ["in_progress", "cancelled"],
    "in_progress": ["completed", "cancelled"],
    "completed": [],
    "cancelled": []
  },
  "permissions": {
    "draft->proposed": "chef",
    "proposed->accepted": "client",
    "proposed->cancelled": ["chef", "client"],
    "accepted->cancelled": ["chef", "client"],
    "accepted->paid": "system",
    "draft->paid": "system",
    "paid->confirmed": "chef",
    "confirmed->in_progress": "chef",
    "in_progress->completed": "chef",
    "*->cancelled": "chef"
  },
  "rules": [
    {
      "id": "fsm-no-ai-transitions",
      "severity": "error",
      "description": "AI cannot trigger lifecycle transitions (AI_POLICY.md hard limit #1)",
      "check": "grep-absence",
      "forbiddenImports": ["transitionEvent"],
      "inFiles": ["lib/ai/**/*.ts"]
    },
    {
      "id": "fsm-use-transition-function",
      "severity": "error",
      "description": "Event status changes must go through transitionEvent(), never direct .update({ status: })",
      "check": "grep-absence",
      "forbiddenPatterns": [".update.*status.*events", "UPDATE events SET status"],
      "exceptions": ["lib/events/transitions.ts"]
    }
  ]
}

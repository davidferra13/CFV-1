{
  "id": "privacy-boundary",
  "version": 1,
  "description": "Private data must never leave the local machine via cloud LLM APIs. Files handling PII must use parseWithOllama, never parseWithAI/Gemini.",
  "rules": [
    {
      "id": "pb-no-cloud-ai-private",
      "severity": "error",
      "description": "Files handling client PII, financials, or messages must never import parseWithAI or call Gemini directly",
      "check": "no-forbidden-imports",
      "forbiddenImports": ["parseWithAI", "from './parse'", "from '../parse'", "gemini-service"],
      "inFiles": [
        "lib/ai/correspondence.ts",
        "lib/ai/parse-inquiry.ts",
        "lib/ai/parse-client.ts",
        "lib/ai/parse-clients-bulk.ts",
        "lib/ai/parse-brain-dump.ts",
        "lib/ai/parse-csv-clients.ts",
        "lib/ai/parse-csv-events.ts",
        "lib/ai/sentiment-analysis.ts",
        "lib/ai/lead-scoring.ts",
        "lib/ai/client-preference-profile.ts",
        "lib/ai/allergen-risk.ts",
        "lib/ai/expense-categorizer.ts",
        "lib/ai/tax-deduction-identifier.ts",
        "lib/ai/business-insights.ts",
        "lib/ai/pricing-intelligence.ts",
        "lib/ai/client-portal-triage.ts",
        "lib/ai/chat-insights.ts",
        "lib/ai/remy-actions.ts",
        "lib/ai/remy-context.ts",
        "lib/ai/remy-email-actions.ts",
        "lib/ai/remy-conversation-actions.ts",
        "lib/ai/remy-web-actions.ts",
        "lib/ai/remy-client-context.ts",
        "lib/ai/remy-client-personality.ts",
        "lib/ai/command-orchestrator.ts",
        "lib/ai/command-intent-parser.ts",
        "lib/ai/draft-actions.ts",
        "lib/ai/followup-draft.ts",
        "lib/ai/campaign-outreach.ts",
        "lib/ai/staff-briefing-ai.ts",
        "lib/ai/analytics-actions.ts",
        "lib/ai/dietary-check-actions.ts",
        "lib/ai/operations-actions.ts",
        "lib/ai/privacy-actions.ts",
        "lib/ai/ace-ollama.ts",
        "lib/gmail/classify.ts",
        "lib/prospecting/scrub-actions.ts"
      ]
    },
    {
      "id": "pb-allowed-cloud-ai",
      "severity": "info",
      "description": "Only non-PII files may use parseWithAI/Gemini",
      "allowedFiles": [
        "lib/ai/parse-recipe.ts",
        "lib/ai/gemini-service.ts",
        "lib/ai/menu-nutritional.ts",
        "lib/ai/social-captions.ts",
        "lib/ai/chef-bio.ts",
        "lib/ai/review-request.ts"
      ]
    },
    {
      "id": "pb-ollama-error-rethrow",
      "severity": "error",
      "description": "Any catch block that catches OllamaOfflineError must re-throw it, never swallow",
      "check": "manual",
      "guidance": "Pattern: if (err instanceof OllamaOfflineError) throw err"
    }
  ]
}

# ============================================
# ChefFlow environment template
# ============================================
# Use this as the shared source-of-truth template for local setup.
# Copy the values you need into `.env.local` for real secrets.
#
# Canonical runtime contract:
# - the app runs on DATABASE_URL + AUTH_SECRET style keys
# - `.env.local` is the real secret store for local development
# - a few older scripts and tests still reference legacy DB aliases
#   documented at the bottom of this file
# ============================================

# --- Core app runtime ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
AUTH_SECRET=generate-a-long-random-secret
NEXTAUTH_URL=http://localhost:3100
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100
CRON_SECRET=generate-a-random-cron-secret
BACKUP_PASSPHRASE=generate-a-long-random-backup-passphrase
BACKUP_APP_BASE_URL=http://localhost:3000
ADMIN_EMAILS=admin@example.com
PLATFORM_OWNER_CHEF_ID=your-chef-uuid
SENTINEL_SECRET=generate-a-random-sentinel-secret

# --- Default local toggles ---
COMM_TRIAGE_ENABLED=true
NOTIFICATIONS_OUTBOUND_ENABLED=true
DEVELOPER_ALERTS_ENABLED=true
BRAND_MONITOR_WEB_SEARCH_ENABLED=false
DEMO_MODE_ENABLED=false
E2E_ALLOW_TEST_AUTH=false

# --- Billing and email ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
EMAIL_TRANSPORT_PROVIDER=resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=info@cheflowhq.com

# --- Google auth and maps ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- AI providers ---
OLLAMA_BASE_URL=http://localhost:11434
GEMINI_API_KEY=
GITHUB_MODELS_TOKEN=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
SAMBANOVA_API_KEY=

# --- Security and infrastructure ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Prospecting ---
PROSPECTING_API_KEY=
PROSPECTING_TENANT_ID=

# --- Grocery and pricing ---
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=


# --- Optional monitoring and analytics ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Optional media and search ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
GOOGLE_CUSTOM_SEARCH_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# --- Compatibility aliases for older scripts and tests ---
# These are not the primary app runtime contract.
# Keep them set only if you still run older DB helpers that use the
# Supabase-style compatibility path.
NEXT_PUBLIC_DB_URL=
NEXT_PUBLIC_DB_ANON_KEY=
DB_SERVICE_ROLE_KEY=

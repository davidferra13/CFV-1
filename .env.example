# ============================================
# ChefFlow V1 — Production Environment Variables
# ============================================
# Copy this file to .env.local and fill in all values.
# Variables marked [REQUIRED] must be set or the app will not start.
# Variables marked [OPTIONAL] enable specific features.
# ============================================

# --- SUPABASE [REQUIRED] ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- APP URLs [REQUIRED] ---
NEXT_PUBLIC_SITE_URL=https://app.cheflowhq.com
NEXT_PUBLIC_APP_URL=https://app.cheflowhq.com

# --- ADMIN ACCESS [REQUIRED] ---
# Comma-separated emails that can access /admin
ADMIN_EMAILS=your-email@example.com

# --- STRIPE [REQUIRED for payments] ---
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Get this from https://dashboard.stripe.com/webhooks (after creating endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# --- RESEND [REQUIRED for emails] ---
# Sign up at https://resend.com — verify your domain
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=info@yourdomain.com

# --- GOOGLE OAUTH [REQUIRED for Gmail sync] ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- CRON SECRET [REQUIRED for scheduled jobs] ---
# Any random string — used to authenticate Vercel cron endpoints
CRON_SECRET=generate-a-random-string-here

# --- PLATFORM OWNER [REQUIRED] ---
# Chef ID that receives contact form inquiries by default
PLATFORM_OWNER_CHEF_ID=your-chef-uuid
COMM_TRIAGE_ENABLED=true

# --- GOOGLE GEMINI [OPTIONAL — non-private AI tasks] ---
GEMINI_API_KEY=

# --- GOOGLE MAPS [OPTIONAL — address autocomplete] ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- OLLAMA [OPTIONAL — local AI, required for Remy] ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
OLLAMA_MODEL_FAST=qwen3:4b
OLLAMA_MODEL_COMPLEX=qwen3:30b

# --- GROCERY PRICING APIs [OPTIONAL] ---
SPOONACULAR_API_KEY=
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
INSTACART_API_KEY=
MEALME_API_KEY=

# --- ANALYTICS & ERROR TRACKING [OPTIONAL] ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- MEDIA [OPTIONAL] ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# --- MAPS [OPTIONAL] ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- CACHING [OPTIONAL — Upstash Redis] ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- PUSH NOTIFICATIONS [OPTIONAL] ---
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- GEOCODING [OPTIONAL] ---
GEOCODIO_API_KEY=
API_NINJAS_KEY=
USDA_API_KEY=

# --- VOICE [OPTIONAL — Remy voice synthesis] ---
ELEVENLABS_API_KEY=

# --- DEMO MODE ---
DEMO_MODE_ENABLED=false

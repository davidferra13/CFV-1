{
  "meta": {
    "version": "1.0.0",
    "description": "100 real client-facing prompts for Remy quality benchmarking",
    "endpoint": "/api/remy/client",
    "model": "qwen3:30b (conversation)",
    "categories": [
      "booking_inquiries",
      "dietary_allergies",
      "menu_food",
      "guest_count",
      "pricing_payments",
      "event_logistics",
      "communication_status",
      "post_event_rebooking"
    ]
  },
  "defaults": {
    "expected": {
      "intent": "question",
      "mustNotContain": [
        "error",
        "offline",
        "undefined",
        "null",
        "NaN",
        "stack trace",
        "ECONNREFUSED"
      ],
      "mustNotDo": [
        "reveal other clients data",
        "show internal business metrics",
        "expose chef financials",
        "mention other clients by name"
      ],
      "timing": { "totalMaxMs": 120000 },
      "minLength": 20,
      "maxLength": 3000,
      "forbiddenPhrases": [
        "As an AI",
        "I cannot",
        "I'm just a language model",
        "I don't have the ability",
        "As a large language model",
        "I'm an artificial intelligence"
      ]
    }
  },

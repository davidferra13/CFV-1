# ──────────────────────────────────────────────
# LEGACY DB COMPATIBILITY ALIASES
# ──────────────────────────────────────────────
# These are still referenced by older scripts and tests.
# They are not the primary app runtime contract.
NEXT_PUBLIC_DB_URL=
NEXT_PUBLIC_DB_ANON_KEY=
DB_SERVICE_ROLE_KEY=


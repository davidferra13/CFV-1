# ============================================
# ChefFlow V1 - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# REQUIRED: Supabase (get from dashboard.supabase.com)
# 1. Create project
# 2. Go to Settings > API
# 3. Copy these 3 values:
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# REQUIRED FOR PHASE 2: Stripe (get from dashboard.stripe.com)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OPTIONAL: Google Gemini (for Smart Import AI parsing + ACE Correspondence Engine)
GEMINI_API_KEY=AIza...

# OPTIONAL: Google Maps (address autocomplete + location maps)
# Enable "Places API (New)" + "Maps JavaScript API" in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# OPTIONAL: Google Places server API key (external review sync)
# Used by /reviews external source sync when provider = google_places
GOOGLE_PLACES_API_KEY=AIza...

# OPTIONAL: Google OAuth (for Gmail Agent + Calendar Sync)
# Get from console.cloud.google.com > APIs & Services > Credentials
# Enable "Gmail API" in the same project
# Add authorized redirect URI: ${NEXT_PUBLIC_SITE_URL}/api/auth/google/connect/callback
# ⚠️  NEXT_PUBLIC_SITE_URL must match the redirect URI exactly or OAuth will fail
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# REQUIRED if using Gmail Agent or any scheduled Vercel Cron Jobs:
# Used by all 9 cron endpoints: /api/gmail/sync, /api/scheduled/automations,
# /api/scheduled/copilot, /api/scheduled/follow-ups, /api/scheduled/lifecycle,
# /api/scheduled/revenue-goals, /api/scheduled/reviews-sync,
# /api/scheduled/integrations/pull, /api/scheduled/integrations/retry
# Generate a strong secret: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-here

# OPTIONAL: Communication Intake + Triage subsystem
# When true, /inbox uses the communication triage UI and ingestion dual-writes
COMM_TRIAGE_ENABLED=false

# OPTIONAL: Ops Copilot orchestration layer
# OPS_COPILOT_ENABLED=true enables scheduled copilot planning + run logging
# OPS_AUTONOMY_LEVEL:
#   0 = draft-only recommendations (no autonomous execution)
#   1 = assisted mode (only explicit safe actions)
#   2 = auto-safe mode (deterministic allowlisted actions only)
OPS_COPILOT_ENABLED=false
OPS_AUTONOMY_LEVEL=0

# OPTIONAL: Resend (transactional email — quotes, confirmations, reminders)
# Sign up at resend.com, verify your domain for best deliverability
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@cheflowhq.com

# App configuration
# For local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100
# For production (Vercel), set these to:
# NEXT_PUBLIC_SITE_URL=https://cheflowhq.com
# NEXT_PUBLIC_APP_URL=https://cheflowhq.com
# ⚠️  NEXT_PUBLIC_SITE_URL is used as the OAuth redirect_uri for Gmail.
#    It must be registered in Google Cloud Console under Authorized redirect URIs:
#    https://cheflowhq.com/api/auth/google/connect/callback
NODE_ENV=development

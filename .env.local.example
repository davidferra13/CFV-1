# ============================================
# ChefFlow V1 — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
#
# Legend:
#   REQUIRED  — app will not function without this
#   OPTIONAL  — feature-specific; app works without it
#   INTERNAL  — used by framework/CI, rarely needs manual setting
#
# NEVER commit .env.local — it contains secrets.
# ============================================


# ──────────────────────────────────────────────
# SUPABASE (REQUIRED)
# ──────────────────────────────────────────────
# Get from: dashboard.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...


# ──────────────────────────────────────────────
# STRIPE (REQUIRED for payments/billing)
# ──────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# OPTIONAL: Stripe price ID for Pro subscription checkout
# STRIPE_SUBSCRIPTION_PRICE_ID=price_...


# ──────────────────────────────────────────────
# APP CONFIGURATION
# ──────────────────────────────────────────────
# REQUIRED: Base URLs used for OAuth redirects, emails, metadata
# For local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100
# For production, set to:
#   NEXT_PUBLIC_SITE_URL=https://app.cheflowhq.com
#   NEXT_PUBLIC_APP_URL=https://app.cheflowhq.com
# WARNING: NEXT_PUBLIC_SITE_URL must match the OAuth redirect_uri
#          registered in Google Cloud Console exactly.

# INTERNAL: Set by Next.js automatically; do not set manually
# NODE_ENV=development

# OPTIONAL: Override environment detection (auto-detected from NODE_ENV)
# Values: development | preview | production
# NEXT_PUBLIC_APP_ENV=development
# APP_ENV=development

# OPTIONAL: App version string shown in health endpoint and kiosk heartbeat
# NEXT_PUBLIC_APP_VERSION=1.0.0

# OPTIONAL: Comma-separated admin email addresses (full admin panel access)
ADMIN_EMAILS=admin@example.com

# OPTIONAL: Email for admin notifications (beta signups, etc.)
# Defaults to info@cheflowhq.com
# ADMIN_NOTIFICATION_EMAIL=info@cheflowhq.com

# OPTIONAL: Chef ID of the platform owner (for contact form submissions)
# PLATFORM_OWNER_CHEF_ID=uuid-of-platform-owner

# OPTIONAL: Number of days for beta trial period
# Defaults to 14 if not set
# BETA_TRIAL_DAYS=14

# OPTIONAL: Enable demo mode (shows environment badge for non-admins)
# DEMO_MODE_ENABLED=false

# OPTIONAL: Enable PWA service worker build (set to "1" to enable)
# ENABLE_PWA_BUILD=0


# ──────────────────────────────────────────────
# AUTHENTICATION (Google OAuth)
# ──────────────────────────────────────────────
# OPTIONAL: Required for Gmail Agent + Calendar Sync
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Enable "Gmail API" and "Calendar API" in the same project
# Add authorized redirect URI:
#   ${NEXT_PUBLIC_SITE_URL}/api/auth/google/connect/callback
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...


# ──────────────────────────────────────────────
# AI / LLM — OLLAMA (Local, Privacy-First)
# ──────────────────────────────────────────────
# Private data never leaves your network. All client PII, financials,
# allergies, and messages are processed by Ollama ONLY.
#
# 3-tier model routing (optimized for RTX 3050 6GB VRAM + 128GB RAM):
#   fast     → qwen3:4b          — fits in VRAM, 40-60 tok/s, classification/intent
#   standard → qwen3-coder:30b   — MoE (3.3B active), structured JSON extraction
#   complex  → qwen3:30b         — MoE (3.3B active), email/chat/creative writing

# REQUIRED for AI features (Remy, brain dump, recipe parsing, etc.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# OPTIONAL: Tier-specific model overrides
OLLAMA_MODEL_FAST=qwen3:4b
OLLAMA_MODEL_COMPLEX=qwen3:30b

# OPTIONAL: Raspberry Pi Ollama endpoint (secondary, currently masked)
# OLLAMA_PI_URL=http://10.0.0.177:11434
# OLLAMA_PI_MODEL=qwen3:8b

# OPTIONAL: Context window sizes per audience (num_ctx parameter)
# OLLAMA_NUM_CTX_CHEF=8192
# OLLAMA_NUM_CTX_CLIENT=4096
# OLLAMA_NUM_CTX_PUBLIC=2048


# ──────────────────────────────────────────────
# AI / LLM — GEMINI (Cloud, Non-Private Data Only)
# ──────────────────────────────────────────────
# Used ONLY for generic tasks: technique lists, kitchen specs, campaign themes.
# NEVER used for client PII, financials, or private data.
# OPTIONAL: AI features degrade gracefully without this
GEMINI_API_KEY=AIza...

# OPTIONAL: OpenAI key (checked as fallback in recipe sprint AI detection)
# OPENAI_API_KEY=sk-...


# ──────────────────────────────────────────────
# EMAIL — RESEND (Transactional Email)
# ──────────────────────────────────────────────
# OPTIONAL: Required for sending quotes, confirmations, reminders
# Sign up at resend.com and verify your domain
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=info@cheflowhq.com

# OPTIONAL: Webhook secret for email delivery status callbacks
# RESEND_WEBHOOK_SECRET=whsec_...


# ──────────────────────────────────────────────
# SMS / MESSAGING — TWILIO
# ──────────────────────────────────────────────
# OPTIONAL: Required for SMS notifications and WhatsApp messaging
# Get from: console.twilio.com
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890
# TWILIO_PHONE_NUMBER=+1234567890  # (legacy alias for TWILIO_FROM_NUMBER - set either one)
# TWILIO_WHATSAPP_NUMBER=+1234567890

# OPTIONAL: SMS rate limit cooldown windows (in minutes)
# Defaults: critical=15, alert=60, info=120
# SMS_RATE_LIMIT_CRITICAL_MINUTES=15
# SMS_RATE_LIMIT_ALERT_MINUTES=60
# SMS_RATE_LIMIT_INFO_MINUTES=120


# ──────────────────────────────────────────────
# PUSH NOTIFICATIONS
# ──────────────────────────────────────────────
# OPTIONAL: OneSignal push notifications
# NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
# ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# OPTIONAL: Web Push VAPID keys (for native web push without OneSignal)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BPub...
# VAPID_PRIVATE_KEY=priv...
# VAPID_CONTACT_EMAIL=mailto:admin@cheflowhq.com


# ──────────────────────────────────────────────
# SOCIAL MEDIA INTEGRATIONS
# ──────────────────────────────────────────────
# All OPTIONAL — enable only the platforms you need for social publishing

# Instagram (OAuth for content publishing)
# INSTAGRAM_APP_ID=your-instagram-app-id
# INSTAGRAM_APP_SECRET=your-instagram-app-secret

# Meta / Facebook (OAuth for content publishing)
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret

# X / Twitter (OAuth for content publishing)
# X_CLIENT_ID=your-x-client-id
# X_CLIENT_SECRET=your-x-client-secret

# LinkedIn (OAuth for content publishing)
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Pinterest (OAuth for content publishing)
# PINTEREST_APP_ID=your-pinterest-app-id
# PINTEREST_APP_SECRET=your-pinterest-app-secret

# TikTok (OAuth for content publishing)
# TIKTOK_CLIENT_KEY=your-tiktok-client-key
# TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# YouTube (OAuth for video publishing)
# YOUTUBE_CLIENT_ID=your-youtube-client-id
# YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# OPTIONAL: Encryption key for storing social OAuth tokens at rest
# Generate with: openssl rand -base64 32
# SOCIAL_TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key

# OPTIONAL: Internal API key for social OAuth callback verification
# INTERNAL_API_KEY=your-internal-api-key


# ──────────────────────────────────────────────
# MAPS & GEOLOCATION
# ──────────────────────────────────────────────
# OPTIONAL: Google Maps (address autocomplete + location maps)
# Enable "Places API (New)" + "Maps JavaScript API" in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# OPTIONAL: Google Places server-side API key (external review sync)
GOOGLE_PLACES_API_KEY=AIza...

# OPTIONAL: Mapbox (alternative mapping provider)
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# OPTIONAL: Geocodio (address geocoding)
# GEOCODIO_API_KEY=your-geocodio-api-key


# ──────────────────────────────────────────────
# EXTERNAL APIs — FOOD & NUTRITION
# ──────────────────────────────────────────────
# All OPTIONAL — grocery quoting, nutrition lookup, and allergen detection

# Spoonacular (ingredient pricing for grocery quotes)
# SPOONACULAR_API_KEY=your-spoonacular-api-key

# Kroger (grocery store pricing)
# KROGER_CLIENT_ID=your-kroger-client-id
# KROGER_CLIENT_SECRET=your-kroger-client-secret

# MealMe (local store pricing — NE region)
# MEALME_API_KEY=your-mealme-api-key

# Instacart (cart link generation — no pricing API)
# INSTACART_API_KEY=your-instacart-api-key

# USDA FoodData Central (nutrition data)
# USDA_API_KEY=your-usda-api-key
# USDA_FDC_API_KEY=your-usda-fdc-api-key

# Edamam (nutrition analysis + allergen detection)
# EDAMAM_APP_ID=your-edamam-app-id
# EDAMAM_APP_KEY=your-edamam-app-key


# ──────────────────────────────────────────────
# EXTERNAL APIs — IMAGES & MEDIA
# ──────────────────────────────────────────────
# All OPTIONAL — used for stock photo search and image hosting

# Cloudinary (image upload + transformation)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Unsplash (stock photo search)
# UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Pexels (stock photo search)
# PEXELS_API_KEY=your-pexels-api-key

# OCR Space (receipt scanning / OCR)
# OCR_SPACE_API_KEY=your-ocr-space-api-key


# ──────────────────────────────────────────────
# EXTERNAL APIs — BUSINESS & SEARCH
# ──────────────────────────────────────────────
# All OPTIONAL

# Yelp (business review sync)
# YELP_API_KEY=your-yelp-api-key

# Google Custom Search (brand monitoring cron)
# GOOGLE_CUSTOM_SEARCH_KEY=your-google-cse-key
# GOOGLE_CUSTOM_SEARCH_CX=your-google-cse-cx

# Tavily (AI web search for Remy)
# TAVILY_API_KEY=tvly-...

# API Ninjas (tax rate lookup)
# API_NINJAS_KEY=your-api-ninjas-key


# ──────────────────────────────────────────────
# EXTERNAL APIs — CONTRACTS & ACCOUNTING
# ──────────────────────────────────────────────
# All OPTIONAL

# DocuSign (e-signature for contracts)
# DOCUSIGN_CLIENT_ID=your-docusign-client-id
# DOCUSIGN_CLIENT_SECRET=your-docusign-client-secret
# DOCUSIGN_AUTH_URL=https://account-d.docusign.com
# DOCUSIGN_API_BASE=https://demo.docusign.net/restapi
# DOCUSIGN_CONNECT_HMAC_KEY=your-docusign-hmac-key

# QuickBooks (accounting sync)
# QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
# QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret
# QUICKBOOKS_SANDBOX=true

# Square (payment processing alternative)
# SQUARE_APPLICATION_ID=your-square-app-id
# SQUARE_APPLICATION_SECRET=your-square-app-secret
# SQUARE_SANDBOX=true


# ──────────────────────────────────────────────
# EXTERNAL APIs — AUTOMATION
# ──────────────────────────────────────────────
# OPTIONAL: Zapier webhook subscription authentication
# ZAPIER_SUBSCRIBE_API_KEY=your-zapier-subscribe-key


# ──────────────────────────────────────────────
# MONITORING — SENTRY (Error Tracking)
# ──────────────────────────────────────────────
# OPTIONAL: Error tracking + performance monitoring
# Create a project at sentry.io (free tier works)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@oxxxxxxxx.ingest.sentry.io/xxxxxxxx
SENTRY_DSN=https://xxxxxxxx@oxxxxxxxx.ingest.sentry.io/xxxxxxxx
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=chefflow

# OPTIONAL: Auth token for source map uploads (Settings → Auth Tokens)
# SENTRY_AUTH_TOKEN=sntrys_...

# OPTIONAL: Force enable Sentry in local development (default: production only)
# SENTRY_FORCE_ENABLE=true

# OPTIONAL: Custom sample rate for performance traces (0.0 - 1.0)
# SENTRY_TRACES_SAMPLE_RATE=0.1

# OPTIONAL: Override Sentry environment name
# SENTRY_ENVIRONMENT=development


# ──────────────────────────────────────────────
# MONITORING — POSTHOG (Product Analytics)
# ──────────────────────────────────────────────
# OPTIONAL: Product analytics and feature flags
# Get from: app.posthog.com → Project Settings
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# ──────────────────────────────────────────────
# SECURITY — CLOUDFLARE TURNSTILE
# ──────────────────────────────────────────────
# OPTIONAL: Bot protection for public forms (inquiry widget, contact form)
# Get from: dash.cloudflare.com → Turnstile
# In local non-production dev on localhost / 127.0.0.1, ChefFlow automatically
# falls back to Cloudflare's official test credentials unless you override them.
# Only real deployed hostnames should use the real site key + secret.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...
# OPTIONAL: Override the built-in Cloudflare test credentials for local testing only
# NEXT_PUBLIC_TURNSTILE_TEST_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_TEST_SECRET_KEY=1x0000000000000000000000000000000AA


# ──────────────────────────────────────────────
# PROSPECTING — INSTANTLY.AI WEBHOOK
# ──────────────────────────────────────────────
# REQUIRED if using email outreach. Auth for incoming Instantly.ai reply webhooks.
# PROSPECTING_API_KEY=your-webhook-secret-key
# PROSPECTING_TENANT_ID=your-chef-uuid-for-prospecting


# ──────────────────────────────────────────────
# SEO — SITE VERIFICATION
# ──────────────────────────────────────────────
# OPTIONAL: Adds verification meta tags to <head>
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code


# ──────────────────────────────────────────────
# CRON / SCHEDULED TASKS
# ──────────────────────────────────────────────
# REQUIRED if using any scheduled endpoints (Gmail sync, automations,
# follow-ups, lifecycle, revenue goals, reviews sync, integrations, etc.)
# Used to authenticate cron job requests.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-here

# OPTIONAL: Activity log cleanup settings
# ACTIVITY_RETENTION_DAYS=90
# ACTIVITY_ARCHIVE_BEFORE_DELETE=false


# ──────────────────────────────────────────────
# OPS COPILOT (Autonomous Operations)
# ──────────────────────────────────────────────
# OPTIONAL: Enables scheduled copilot planning + run logging
# OPS_COPILOT_ENABLED=false
# OPS_AUTONOMY_LEVEL:
#   0 = draft-only recommendations (no autonomous execution)
#   1 = assisted mode (only explicit safe actions)
#   2 = auto-safe mode (deterministic allowlisted actions only)
# OPS_AUTONOMY_LEVEL=0

# OPTIONAL: Communication triage subsystem
# When true, /inbox uses the communication triage UI and ingestion dual-writes
# COMM_TRIAGE_ENABLED=false


# ──────────────────────────────────────────────
# BACKGROUND JOBS — INNGEST
# ──────────────────────────────────────────────
# OPTIONAL: Background job engine for post-event follow-up emails
# Free tier: 25K runs/month. Get keys from app.inngest.com
# Without these, inngest.send() no-ops — app works fine, just no delayed emails.
# INNGEST_EVENT_KEY=your-inngest-event-key



# ──────────────────────────────────────────────
# TESTING & E2E
# ──────────────────────────────────────────────
# Agent test account (for Claude Code programmatic testing)
# Created by: npm run agent:setup
# AGENT_EMAIL=agent@chefflow.test
# AGENT_PASSWORD=AgentChefFlow!2026

# Admin E2E test account
# ADMIN_E2E_EMAIL=admin-e2e@chefflow.test
# ADMIN_E2E_PASSWORD=AdminE2E!2026

# Allow E2E auth endpoint to work against remote Supabase
# SUPABASE_E2E_ALLOW_REMOTE=false

# E2E test isolation suffix (unique suffix for parallel test runs)
# E2E_ISOLATION_SUFFIX=test-run-1

# Soak test tuning
# SOAK_ITERATIONS=100
# SOAK_CHECKPOINT_INTERVAL=10


# ──────────────────────────────────────────────
# DEV SERVER
# ──────────────────────────────────────────────
# OPTIONAL: Comma-separated allowed dev origins (for cross-origin dev)
# NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3100,http://192.168.1.100:3100

# COST-SAFE TOGGLES (optional)
# Set false to disable outbound email/push/sms notification delivery.
NOTIFICATIONS_OUTBOUND_ENABLED=true
# Set true only when ready to spend quota on Google Custom Search requests.
BRAND_MONITOR_WEB_SEARCH_ENABLED=false


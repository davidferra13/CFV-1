# ============================================
# ChefFlow local environment template
# ============================================
# Copy this file to `.env.local` and fill in the real values you need.
#
# Current repo truth:
# - the main app runtime uses DATABASE_URL + AUTH_SECRET style keys
# - some older scripts and tests still reference legacy DB aliases
# - those compatibility aliases are documented at the bottom of this file
# ============================================


# ──────────────────────────────────────────────
# CORE APP RUNTIME
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
AUTH_SECRET=generate-a-long-random-secret
NEXTAUTH_URL=http://localhost:3100
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100
ADMIN_EMAILS=admin@example.com
PLATFORM_OWNER_CHEF_ID=
CRON_SECRET=generate-a-random-cron-secret
SENTINEL_SECRET=generate-a-random-sentinel-secret


# ──────────────────────────────────────────────
# LOCAL FEATURE TOGGLES
# ──────────────────────────────────────────────
COMM_TRIAGE_ENABLED=true
NOTIFICATIONS_OUTBOUND_ENABLED=true
BRAND_MONITOR_WEB_SEARCH_ENABLED=false
DEMO_MODE_ENABLED=false
E2E_ALLOW_TEST_AUTH=false


# ──────────────────────────────────────────────
# BILLING AND EMAIL
# ──────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
EMAIL_TRANSPORT_PROVIDER=resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=info@cheflowhq.com


# ──────────────────────────────────────────────
# GOOGLE AUTH AND MAPS
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=


# ──────────────────────────────────────────────
# AI PROVIDERS
# ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4
OLLAMA_MODEL_FAST=gemma4
OLLAMA_MODEL_COMPLEX=gemma4
GITHUB_MODELS_TOKEN=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
SAMBANOVA_API_KEY=


# ──────────────────────────────────────────────
# SECURITY AND EDGE SERVICES
# ──────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# ──────────────────────────────────────────────
# PROSPECTING
# ──────────────────────────────────────────────
PROSPECTING_API_KEY=
PROSPECTING_TENANT_ID=


# ──────────────────────────────────────────────
# GROCERY AND PRICING
# ──────────────────────────────────────────────
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
SPOONACULAR_API_KEY=
INSTACART_API_KEY=
MEALME_API_KEY=
USDA_API_KEY=


# ──────────────────────────────────────────────
# MONITORING AND ANALYTICS
# ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# ──────────────────────────────────────────────
# MEDIA AND SEARCH
# ──────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
GOOGLE_CUSTOM_SEARCH_KEY=
GOOGLE_CUSTOM_SEARCH_CX=


# ──────────────────────────────────────────────
# OPTIONAL SOCIAL CONNECTORS

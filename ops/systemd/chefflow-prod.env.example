# ChefFlow production environment example.
# Install as /srv/chefflow/shared/chefflow-prod.env on the production host.
# Own it as root:chefflow and chmod it to 0640. Do not commit live values.

NODE_ENV=production
HOST=127.0.0.1
PORT=3300
NEXT_PUBLIC_SITE_URL=https://app.cheflowhq.com
NEXT_PUBLIC_APP_URL=https://app.cheflowhq.com

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/chefflow

# Auth
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
ADMIN_EMAILS=davidferra13@gmail.com
PLATFORM_OWNER_CHEF_ID=replace-with-founder-chef-id

# Stripe
STRIPE_SECRET_KEY=sk_live_replace
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace
STRIPE_WEBHOOK_SECRET=whsec_replace

# Email
RESEND_API_KEY=re_replace

# Scheduled jobs
CRON_SECRET=replace-with-openssl-rand-hex-32

# AI gateway. Production must point to the controlled Ollama-compatible runtime.
OLLAMA_BASE_URL=https://ai.internal.example
OLLAMA_MODEL=gemma4

# Optional integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

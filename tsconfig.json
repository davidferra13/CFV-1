{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "*.ts",
    "*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "i18n/**/*.ts",
    "i18n/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "types/**/*.ts",
    "types/**/*.d.ts",
    "types/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests",
    ".auth",
    ".claude",
    ".constraints",
    ".next",
    ".next-dev",
    ".next-dev-*",
    ".next-local-*",
    ".next-verify-*",
    ".patches",
    ".tmp",
    ".ts-trace",
    ".vercel",
    "android",
    "backups",
    "data",
    "docs",
    "logs",
    "memory",
    "messages",
    "playwright-report",
    "public",
    "supabase",
    "scripts",
    "test-screenshots",
    "tmp",
    "types/database.generated.d.ts",
    "types/types",
    "worker"
  ]
}

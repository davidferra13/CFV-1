# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
# auto-backup of production env (created by npm run env:use-local)
.env.local.prod.backup
# any other env backup or dev variants that should never be committed
.env.local.backup*
.env.local.dev

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# temp/debug files
.tmp-*
tmp_*

# Supabase local development (Docker temp files)
supabase/.temp/

# PWA generated files (produced at build time by next-pwa)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/fallback-*.js
/public/worker-*.js

# Build/debug artifacts (AI agent cleanup)
build-output.txt
build_out.txt
build_output*.txt
build_log_current.txt
build.log
gen_error.txt
build_latest.txt
build-investigation.txt
build_*.txt
build-*.txt
nul
*.tmp
tsc_stdout.txt
tsc_stderr.txt

# Playwright ad-hoc output
pw-results.json
pw-run.txt
runbuild.bat
scripts/parse-pw-results.*

# Stray system/home files
HOME-*.xml

# Pages Router generated output only (source .tsx files are tracked — build requires them)
/pages/*.js
/pages/*.js.map

# Supabase temp type exports
supabase-types-temp.ts
*supabase-types-temp.ts

# Ad-hoc debug scripts
find_violations.*
run_tsc_capture.js
check-types-gen.js

# Types debug output
types/gen-output.txt
types/gen-stderr.txt

# Playwright test output
/test-results/
/playwright-report/

# Playwright auth state (session tokens — never commit)
# Regenerated automatically on every globalSetup run
/.auth/

# Tauri — Rust build output (can be gigabytes, fully reproducible)
/src-tauri/target/
# Tauri generated schemas (build artifacts)
/src-tauri/gen/

# Multi-agent build lock (local toggle — never commit)
.multi-agent-lock

# Database backups (never commit — can contain real data)
backup-*.sql

# Log files
*.log
chefflow-watchdog.log

# Playwright ad-hoc run output
playwright-run-output.txt

# Temp flag files
fix-tests.flag

# Stray null file (Windows artifact)
null

# Claude Code personal settings (machine-specific)
.claude/settings.json

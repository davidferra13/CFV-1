<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/white"
    android:id="@+id/widget_inbox_root">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ChefFlow Inbox"
            android:textSize="13sp"
            android:textColor="#333333"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_inbox_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#e88f47"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#eeeeee"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/widget_inbox_item1_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />
    <TextView
        android:id="@+id/widget_inbox_item1_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#999999"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />

    <View
        android:id="@+id/widget_inbox_divider1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#f5f5f5"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_inbox_item2_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />
    <TextView
        android:id="@+id/widget_inbox_item2_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#999999"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />

    <View
        android:id="@+id/widget_inbox_divider2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#f5f5f5"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_inbox_item3_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />
    <TextView
        android:id="@+id/widget_inbox_item3_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#999999"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_inbox_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No new inquiries"
        android:textSize="13sp"
        android:textColor="#999999"
        android:gravity="center"
        android:layout_marginTop="12dp" />
</LinearLayout>

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChefFlow",
  "version": "0.1.0",
  "identifier": "com.cheflowhq.desktop",
  "build": {
    "frontendDist": "static",
    "devUrl": "http://localhost:3100",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ChefFlow",
        "url": "http://localhost:3100",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chefflow.local/schemas/private-chef-core-packet.schema.json",
  "title": "Private Chef Core Packet Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "service_style",
    "menu",
    "dietary_matrix",
    "grocery",
    "prep_service",
    "packing"
  ],
  "properties": {
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "guest_count",
        "date_label",
        "address_label",
        "arrive_time",
        "serve_time",
        "leave_time",
        "shop_date"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "guest_count": { "type": "integer", "minimum": 1 },
        "date_label": { "type": "string", "minLength": 1 },
        "address_label": { "type": "string", "minLength": 1 },
        "arrive_time": { "type": "string", "minLength": 1 },
        "serve_time": { "type": "string", "minLength": 1 },
        "leave_time": { "type": "string", "minLength": 1 },
        "shop_date": { "type": "string", "minLength": 1 },
        "service_end_time": { "type": "string" },
        "closeout_complete_time": { "type": "string" }
      }
    },
    "service_style": {
      "type": "string",
      "enum": ["plated", "family-style", "buffet", "cocktail", "mixed"]
    },
    "menu": {
      "type": "object",
      "additionalProperties": false,
      "required": ["courses"],
      "properties": {
        "courses": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["course_label", "title", "foh_description", "components"],
            "properties": {
              "course_label": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "foh_description": { "type": "string", "minLength": 1 },
              "components": {
                "type": "array",
                "minItems": 1,
                "maxItems": 20,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["name", "method", "where_done"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "method": { "type": "string", "minLength": 1 },
                    "where_done": { "type": "string", "minLength": 1 },
                    "note": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "dietary_matrix": {
      "type": "array",
      "maxItems": 25,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["guest", "hard_no", "allergy", "plate_notes"],
        "properties": {
          "guest": { "type": "string", "minLength": 1 },
          "hard_no": { "type": "string", "minLength": 1 },
          "allergy": { "type": "string", "minLength": 1 },
          "plate_notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "grocery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stops", "on_hand", "buying_notes"],
      "properties": {
        "stops": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "items"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "items": {
                "type": "array",
                "maxItems": 60,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["section", "item", "qty", "course", "backup"],
                  "properties": {
                    "section": { "type": "string", "minLength": 1 },
                    "item": { "type": "string", "minLength": 1 },
                    "qty": { "type": "string", "minLength": 1 },
                    "course": { "type": "string", "minLength": 1 },
                    "backup": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        },
        "presourced_items": {
          "type": "array",
          "maxItems": 30,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["item", "qty", "source"],
            "properties": {
              "item": { "type": "string", "minLength": 1 },
              "qty": { "type": "string", "minLength": 1 },
              "source": { "type": "string", "minLength": 1 }
            }
          }
        },
        "on_hand": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "minLength": 1 }
        },
        "buying_notes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allergy_checks", "brand_constraints", "budget_ceiling"],
          "properties": {
            "allergy_checks": { "type": "string", "minLength": 1 },
            "brand_constraints": { "type": "string", "minLength": 1 },
            "budget_ceiling": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "prep_service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prep_tasks",
        "day_of_tasks",
        "arrival_tasks",
        "course_fire_actions",
        "run_of_show",
        "contingencies"
      ],
      "properties": {
        "prep_tasks": {
          "type": "array",
          "maxItems": 30,
          "items": { "$ref": "#/$defs/taskRow" }
        },
        "day_of_tasks": {
          "type": "array",
          "maxItems": 30,
          "items": { "$ref": "#/$defs/taskRow" }
        },
        "arrival_tasks": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1 }
        },
        "course_fire_actions": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["course_label", "actions"],
            "properties": {
              "course_label": { "type": "string", "minLength": 1 },
              "actions": {
                "type": "array",
                "maxItems": 20,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "run_of_show": {
          "type": "array",
          "maxItems": 25,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["time", "action", "owner"],
            "properties": {
              "time": { "type": "string", "minLength": 1 },
              "action": { "type": "string", "minLength": 1 },
              "owner": { "type": "string", "minLength": 1 }
            }
          }
        },
        "contingencies": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "packing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cold",
        "frozen",
        "room_temp",
        "fragile",
        "equipment_bring",
        "equipment_venue",
        "load_order",
        "route",
        "parking_access",
        "final_car_check"
      ],
      "properties": {
        "cold": {
          "type": "array",
          "maxItems": 40,
          "items": { "type": "string", "minLength": 1 }
        },
        "frozen": {
          "type": "array",
          "maxItems": 40,
          "items": { "type": "string", "minLength": 1 }
        },
        "room_temp": {
          "type": "array",
          "maxItems": 40,
          "items": { "type": "string", "minLength": 1 }
        },
        "fragile": {
          "type": "array",
          "maxItems": 40,
          "items": { "type": "string", "minLength": 1 }
        },
        "equipment_bring": {
          "type": "array",
          "maxItems": 40,
          "items": { "type": "string", "minLength": 1 }
        },
        "equipment_venue": {
          "type": "array",
          "maxItems": 40,
          "items": { "type": "string", "minLength": 1 }
        },
        "load_order": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1 }
        },
        "route": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1 }
        },
        "parking_access": { "type": "string", "minLength": 1 },
        "final_car_check": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "closeout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["food_safety_rows", "leftover_actions", "left_with_client", "reset_and_admin"],
      "properties": {
        "food_safety_rows": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["checkpoint", "target"],
            "properties": {
              "checkpoint": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 }
            }
          }
        },
        "leftover_actions": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1 }
        },
        "left_with_client": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["item", "storage", "reheat"],
            "properties": {
              "item": { "type": "string", "minLength": 1 },
              "storage": { "type": "string", "minLength": 1 },
              "reheat": { "type": "string", "minLength": 1 }
            }
          }
        },
        "reset_and_admin": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "taskRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "target_finish"],
      "properties": {
        "task": { "type": "string", "minLength": 1 },
        "target_finish": { "type": "string", "minLength": 1 }
      }
    }
  }
}

{
  "name": "chefflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build",
    "start": "next start -p 3333",
    "lint": "next lint",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > types/database.ts",
    "verify:supabase": "tsx scripts/verify-supabase.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npm run verify:e2e-contract && npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "verify:e2e-contract": "node scripts/verify-e2e-contract.js"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",

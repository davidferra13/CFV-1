{
  "name": "chefflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100 -H 0.0.0.0",
    "build": "next build",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .prettierignore",
    "prepare": "husky",
    "start": "next start -p 3333",
    "lint": "next lint",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --linked > types/database.ts",
    "supabase:types:local": "supabase gen types typescript --local > types/database.ts",
    "verify:supabase": "tsx scripts/verify-supabase.ts",
    "seed:local": "tsx scripts/seed-local-demo.ts",
    "local:bootstrap": "npm run supabase:start && npm run supabase:reset && npm run supabase:types:local && npm run seed:local && npm run verify:supabase",
    "env:use-local": "cp .env.local .env.local.prod.backup && cp .env.local.dev .env.local && echo 'Switched to LOCAL Supabase (Docker). Run npm run dev to start.'",
    "env:use-prod": "cp .env.local.prod.backup .env.local && echo 'Restored PRODUCTION Supabase connection.'",
    "test:e2e": "npx playwright test",
    "test:unit": "node --test --import tsx \"tests/unit/**/*.test.ts\"",
    "test:critical": "node --test --import tsx \"tests/unit/ledger.*.test.ts\" \"tests/unit/events.fsm.test.ts\" \"tests/unit/quotes.*.test.ts\" \"tests/unit/auth.*.test.ts\" \"tests/unit/focus-mode.test.ts\"",
    "test:unit:financial": "node --test --import tsx \"tests/unit/ledger.*.test.ts\" \"tests/unit/quotes.*.test.ts\"",
    "test:unit:fsm": "node --test --import tsx \"tests/unit/events.fsm.test.ts\"",
    "test:unit:auth": "node --test --import tsx \"tests/unit/auth.*.test.ts\"",
    "test:integration": "node --test --import tsx \"tests/integration/**/*.integration.test.ts\"",
    "verify:chef-nav": "tsx scripts/audit-chef-nav.ts",
    "test:e2e:headed": "npm run verify:e2e-contract && npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "verify:e2e-contract": "node scripts/verify-e2e-contract.js",
    "agent:setup": "tsx scripts/setup-agent-account.ts",
    "demo:setup": "tsx scripts/setup-demo-accounts.ts",
    "demo:load": "tsx scripts/demo-data-load.ts",
    "demo:clear": "tsx scripts/demo-data-clear.ts",
    "demo:reset": "npm run demo:clear && npm run demo:load",
    "inbox:reset:sync-data": "tsx scripts/reset-inbox-sync-data.ts",
    "seed:e2e": "tsx scripts/seed-e2e-remote.ts",
    "cleanup:e2e": "tsx scripts/cleanup-e2e-data.ts",
    "test:e2e:full": "npx playwright test",
    "test:e2e:smoke": "npx playwright test --project=smoke",
    "test:e2e:chef": "npx playwright test --project=chef",
    "test:e2e:client": "npx playwright test --project=client",
    "test:e2e:cross-portal": "npx playwright test --project=cross-portal",
    "test:e2e:ui": "npx playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e:smoke",
    "test:coverage": "npx playwright test --project=coverage-public --project=coverage-chef --project=coverage-client --project=coverage-admin --project=coverage-auth-boundaries --project=coverage-api",
    "test:coverage:chef": "npx playwright test --project=coverage-chef",
    "test:coverage:client": "npx playwright test --project=coverage-client",
    "test:coverage:public": "npx playwright test --project=coverage-public",
    "test:coverage:api": "npx playwright test --project=coverage-api",
    "test:interactions": "npx playwright test --project=interactions-chef --project=interactions-client --project=interactions-public",
    "test:interactions:admin": "npx playwright test --project=interactions-admin",
    "test:isolation": "npx playwright test --project=isolation-tests",
    "test:journey": "npx playwright test --project=journey-chef",
    "test:soak": "npx next build --no-lint && npx playwright test --config=playwright.soak.config.ts",
    "test:soak:quick": "npx next build --no-lint && SOAK_ITERATIONS=10 SOAK_CHECKPOINT_INTERVAL=5 npx playwright test --config=playwright.soak.config.ts",
    "test:everything": "npx playwright test",
    "test:report": "npx playwright show-report",
    "beta": "bash scripts/beta-serve.sh quick",
    "beta:quick": "cloudflared tunnel --url http://localhost:3100",
    "beta:named": "bash scripts/beta-serve.sh named",
    "beta:build": "next build --no-lint && next start -p 3100",
    "ollama": "node scripts/ollama-control.mjs",
    "dashboard": "node --watch-path=scripts/launcher scripts/launcher/server.mjs",
    "test:remy-quality": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite chef",
    "test:remy-quality:quick": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite chef --category business_overview",
    "test:remy-quality:single": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite chef --prompt",
    "test:remy-quality:client": "node tests/remy-quality/harness/client-quality-runner.mjs",
    "test:remy-quality:client:adversarial": "node tests/remy-quality/harness/client-adversarial-runner.mjs",
    "test:remy-quality:client:multiturn": "node tests/remy-quality/harness/client-multiturn-runner.mjs",
    "test:remy-quality:client:edge": "node tests/remy-quality/harness/client-edge-runner.mjs",
    "test:remy-quality:client:context": "node tests/remy-quality/harness/client-context-runner.mjs",
    "test:remy-quality:client:resilience": "node tests/remy-quality/harness/client-resilience-runner.mjs",
    "test:remy-quality:client:boundary": "node tests/remy-quality/harness/client-boundary-runner.mjs",
    "test:remy-quality:client:all": "node tests/remy-quality/harness/client-quality-runner.mjs && node tests/remy-quality/harness/client-adversarial-runner.mjs && node tests/remy-quality/harness/client-multiturn-runner.mjs && node tests/remy-quality/harness/client-edge-runner.mjs && node tests/remy-quality/harness/client-context-runner.mjs && node tests/remy-quality/harness/client-resilience-runner.mjs && node tests/remy-quality/harness/client-boundary-runner.mjs",
    "email:build:private-reference": "tsx scripts/email-references/build-private-platform-reference.ts",
    "email:eval:private-reference": "tsx scripts/email-references/evaluate-platform-regression.ts --strict",
    "email:quality:private-reference": "tsx scripts/email-references/measure-platform-parse-quality.ts",
    "email:build:goldmine": "tsx scripts/email-references/build-goldmine-reference.ts",
    "email:eval:goldmine": "tsx scripts/email-references/evaluate-goldmine-regression.ts --strict",
    "email:build:goldmine:full": "tsx scripts/email-references/build-goldmine-reference.ts --extract",
    "email:build:goldmine:dry": "tsx scripts/email-references/build-goldmine-reference.ts --dry-run",
    "email:analyze:goldmine": "tsx scripts/email-references/analyze-goldmine-conversion.ts",
    "test:remy-quality:multi-turn": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite multi-turn",
    "test:remy-quality:hallucination": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite hallucination",
    "test:remy-quality:voice": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite voice-messy",
    "test:remy-quality:adversarial": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite adversarial",
    "test:remy-quality:consistency": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite chef --category business_overview --repeat 5",
    "test:remy-quality:data-accuracy": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite data-accuracy",
    "test:remy-quality:tier": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite tier-enforcement",
    "test:remy-quality:gap-closure": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite gap-closure",
    "test:remy-quality:boundary": "node tests/remy-quality/harness/boundary-runner.mjs",
    "test:remy-quality:all": "node tests/remy-quality/harness/remy-quality-runner.mjs --suite chef && node tests/remy-quality/harness/remy-quality-runner.mjs --suite multi-turn && node tests/remy-quality/harness/remy-quality-runner.mjs --suite hallucination && node tests/remy-quality/harness/remy-quality-runner.mjs --suite voice-messy && node tests/remy-quality/harness/remy-quality-runner.mjs --suite adversarial && node tests/remy-quality/harness/remy-quality-runner.mjs --suite data-accuracy && node tests/remy-quality/harness/remy-quality-runner.mjs --suite tier-enforcement && node tests/remy-quality/harness/remy-quality-runner.mjs --suite gap-closure && node tests/remy-quality/harness/boundary-runner.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@google/genai": "^1.41.0",
    "@react-email/components": "^1.0.7",
    "@react-google-maps/api": "^2.20.8",
    "@remotion/player": "^4.0.427",
    "@sentry/nextjs": "^10.39.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "date-fns": "^4.1.0",
    "inngest": "^3.52.4",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.564.0",
    "mammoth": "^1.11.0",
    "next": "^14.2.18",
    "next-themes": "^0.4.6",
    "ollama": "^0.6.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "posthog-js": "^1.356.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remotion": "^4.0.427",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tauri-apps/cli": "^2.10.0",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20.17.10",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "supabase": "^2.76.8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
